# ───────────────────────────────────────────────────────
# InsureDAO — Environment Variables
# ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Deployer private key (DO NOT commit your real key)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Arbitrum Sepolia RPC
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key (for contract verification)
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY

# Chainlink price feed addresses on Arbitrum Sepolia
CHAINLINK_ETH_USD_FEED=0xd30e2101a97dcbAeBCBC04F14C3f624E67A35165
CHAINLINK_USDC_USD_FEED=0x0153002d20B96532C639313c2d54c3dA09109309

# Optional: set to real USDC address on Arbitrum Sepolia
# If not set, a MockERC20 will be deployed
# USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Optional: oracle adapter address (if already deployed in Step 3)
# ORACLE_ADDRESS=0x...
